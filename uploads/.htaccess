#php_flag engine off

<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(jpg|jpeg|png|gif|webp|mp4|webm|svg|ico)$">
    ForceType application/octet-stream
    Header set Content-Disposition attachment
</FilesMatch>

Options -Indexes